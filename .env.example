# EM-FX Desk Co-pilot — configuration
# Copy to `.env` and edit. Every setting has a sensible default and the whole
# project runs offline with no `.env` at all (the LLM layer falls back to a
# deterministic mock). All variables use the EMFX_ prefix and are read by
# pydantic-settings — see src/emfx_copilot/config.py.

# --- LLM layer -------------------------------------------------------------
# Provider: "mock" (default, offline, deterministic) or "anthropic" (real Claude).
EMFX_LLM_PROVIDER=mock
# Model used when EMFX_LLM_PROVIDER=anthropic.
EMFX_LLM_MODEL=claude-opus-4-8
# Max output tokens per call.
EMFX_LLM_MAX_TOKENS=4096
# Thinking/effort budget on Opus-tier models: low | medium | high.
EMFX_LLM_EFFORT=medium
# API key for the Anthropic SDK. Read by the SDK directly; EMFX_ANTHROPIC_API_KEY
# is also accepted. Required only when EMFX_LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# --- Synthetic market ------------------------------------------------------
EMFX_DATA_SEED=7
EMFX_HISTORY_DAYS=520

# --- Risk limits (USD notional) & VaR --------------------------------------
EMFX_GROSS_LIMIT_USD=100000000
EMFX_PER_CCY_LIMIT_USD=25000000
EMFX_MAX_CONCENTRATION=0.40
EMFX_VAR_CONFIDENCE=0.99

# --- Strategy --------------------------------------------------------------
# Round-trip transaction cost (bps) assumed by the walk-forward backtest.
EMFX_COST_BPS=2.0
